{
  "name": "godot-agent-cli-repo",
  "private": true,
  "description": "Repository workspace for the Godot Agent CLI addon. The publishable npm package lives in addons/godot_agent_cli.",
  "scripts": {
    "check": "node addons/godot_agent_cli/cli/bin/gdli.js check",
    "package": "node addons/godot_agent_cli/scripts/package.mjs",
    "npm:dry-run": "npm publish --dry-run --workspace=false ./addons/godot_agent_cli",
    "npm:publish": "npm publish --workspace=false ./addons/godot_agent_cli"
  },
  "engines": {
    "node": ">=18"
  }
}
